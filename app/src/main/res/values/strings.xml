    <!-- Onboarding -->
    <!-- 1 · Cover -->
    <string name="onboarding_cover_title">Coming Home to Yourself</string>
    <string name="onboarding_cover_subtitle">The 30-Day Journal</string>
    <string name="onboarding_cover_tagline">A guided journey, in four movements — from self-acceptance to purpose.</string>
    <string name="onboarding_cover_cta">Begin</string>

    <!-- 2 · Ori arrives -->
    <string name="onboarding_intro_title">Hi — I\'m Ori</string>
    <string name="onboarding_intro_body">I\'ll walk the next thirty days with you.\n\nThis isn\'t about becoming someone else by the end of the month. It\'s about coming back to the person you already are — more honestly, more kindly, and with a clearer sense of where you\'re headed.</string>
    <string name="onboarding_intro_cta">I\'m ready</string>

    <!-- 3 · Name -->
    <string name="onboarding_name_title">First — what should I call you?</string>
    <string name="onboarding_name_hint">Your name</string>
    <string name="onboarding_name_cta">Continue</string>

    <!-- 4 · Mood check-in -->
    <string name="onboarding_mood_title">How are you feeling right now, %s?</string>
    <string name="onboarding_mood_light">Light</string>
    <string name="onboarding_mood_okay">Okay</string>
    <string name="onboarding_mood_tired">Tired</string>
    <string name="onboarding_mood_anxious">Anxious</string>
    <string name="onboarding_mood_heavy">Heavy</string>
    <string name="onboarding_mood_numb">Numb</string>

    <!-- 5 · Ori responds (struggling only) -->
    <string name="onboarding_respond_tired">Tired is allowed here, %s. We\'ll go slow — nothing to fix, nothing to rush. Just a few honest minutes, and then you can rest.</string>
    <string name="onboarding_respond_anxious">Anxious is a hard place to start from, %s. We don\'t have to quiet it — we just give it somewhere to land on the page. Small is okay.</string>
    <string name="onboarding_respond_heavy">That sounds like a lot to carry, %s. You don\'t have to set it down today — just bring it with you to the page. That\'s enough.</string>
    <string name="onboarding_respond_numb">Numb is its own kind of weather, %s. We\'ll start gently, and you don\'t have to feel everything at once. Showing up is the whole task today.</string>
    <string name="onboarding_respond_cta">Continue</string>

    <!-- 6 · Desired feeling -->
    <string name="onboarding_feeling_title">And where would you like this to take you?</string>
    <string name="onboarding_feeling_peace">At peace with myself</string>
    <string name="onboarding_feeling_confident">Confident</string>
    <string name="onboarding_feeling_connected">Connected</string>
    <string name="onboarding_feeling_clear">Clear on what matters</string>

    <!-- 7 · Ori names the journey -->
    <string name="onboarding_stage_connector_peace">Then we\'ll spend real time in Self-Acceptance — it\'s where this whole journey begins, and where peace finds its footing.</string>
    <string name="onboarding_stage_connector_confident">Then Empowerment is going to matter to you — learning to trust and back yourself, a little more each day.</string>
    <string name="onboarding_stage_connector_connected">Then Connection is the part to watch for — we\'re built to belong, and these days walk you toward it.</string>
    <string name="onboarding_stage_connector_clear">Then Purpose is where this is headed — turning everything you uncover into a direction worth walking.</string>
    <string name="onboarding_stages_body">The thirty days move through four stages. We begin with Self-Acceptance, because everything steadier in a life is built on meeting yourself as you are. Then Empowerment — learning to back yourself. Then Connection, because we\'re built to belong. And finally Purpose, where it all becomes a direction worth walking.</string>
    <string name="onboarding_stages_cta">Continue</string>

    <!-- 8 · How a day works -->
    <string name="onboarding_day_title">Every day is built the same way, so the shape can hold you:</string>
    <string name="onboarding_day_reflection">A short reflection to set the theme</string>
    <string name="onboarding_day_prompt">One journal prompt — your main writing</string>
    <string name="onboarding_day_deepdive">Three deep-dives, if you want to go further</string>
    <string name="onboarding_day_reaffirm">A reaffirmation to carry with you</string>
    <string name="onboarding_day_action">A mindful action, under fifteen minutes</string>
    <string name="onboarding_day_evening">An evening reflection to close the day</string>
    <string name="onboarding_day_cta">Continue</string>

    <!-- 9 · The promises -->
    <string name="onboarding_promises_title">A few promises, before we begin:</string>
    <string name="onboarding_promises_1">There\'s no perfect way to do this.</string>
    <string name="onboarding_promises_2">Missing a day isn\'t failing — it\'s being a person. Come back when you can; the page will wait.</string>
    <string name="onboarding_promises_3">Write the true thing, not the impressive thing. No one is grading this.</string>
    <string name="onboarding_promises_cta">I promise</string>

