<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Within</string>
    <string name="slogan">um pensamento positivo de cada vez</string>

    <!-- Onboarding -->
    <!-- 1 · Capa -->
    <string name="onboarding_cover_title">De Volta a Você</string>
    <string name="onboarding_cover_subtitle">O Diário de 30 Dias</string>
    <string name="onboarding_cover_tagline">Uma jornada guiada, em quatro movimentos — da autoaceitação ao propósito.</string>
    <string name="onboarding_cover_cta">Começar</string>

    <!-- 2 · O Ori chega -->
    <string name="onboarding_intro_title">Oi — eu sou o Ori</string>
    <string name="onboarding_intro_body">Vou caminhar com você pelos próximos trinta dias.\n\nIsso não é sobre se tornar outra pessoa até o fim do mês. É sobre voltar a ser quem você já é — com mais honestidade, mais carinho, e uma noção mais clara de pra onde você quer ir.</string>
    <string name="onboarding_intro_cta">Estou pronto</string>

    <!-- 3 · Nome -->
    <string name="onboarding_name_title">Primeiro — como posso te chamar?</string>
    <string name="onboarding_name_hint">Seu nome</string>
    <string name="onboarding_name_cta">Continuar</string>

    <!-- 4 · Como você está -->
    <string name="onboarding_mood_title">Como você está se sentindo agora, %s?</string>
    <string name="onboarding_mood_light">Leve</string>
    <string name="onboarding_mood_okay">Tranquilo</string>
    <string name="onboarding_mood_tired">Cansado</string>
    <string name="onboarding_mood_anxious">Ansioso</string>
    <string name="onboarding_mood_heavy">Pesado</string>
    <string name="onboarding_mood_numb">Anestesiado</string>

    <!-- 5 · O Ori responde (só quando está difícil) -->
    <string name="onboarding_respond_tired">Cansaço tem espaço aqui, %s. A gente vai devagar — nada pra consertar, nada pra apressar. Só alguns minutos honestos, e depois você pode descansar.</string>
    <string name="onboarding_respond_anxious">Ansiedade é um lugar difícil pra começar, %s. A gente não precisa silenciá-la — só dar a ela um lugar pra pousar na página. Pequeno está ótimo.</string>
    <string name="onboarding_respond_heavy">Parece muita coisa pra carregar, %s. Você não precisa largar esse peso hoje — só trazer ele junto pra página. Já é o suficiente.</string>
    <string name="onboarding_respond_numb">Anestesia é um tipo de clima também, %s. A gente começa com calma, e você não precisa sentir tudo de uma vez. Aparecer já é a tarefa inteira de hoje.</string>
    <string name="onboarding_respond_cta">Continuar</string>

    <!-- 6 · Como você gostaria de se sentir -->
    <string name="onboarding_feeling_title">E aonde você gostaria que isso te levasse?</string>
    <string name="onboarding_feeling_peace">Em paz comigo mesmo</string>
    <string name="onboarding_feeling_confident">Confiante</string>
    <string name="onboarding_feeling_connected">Conectado</string>
    <string name="onboarding_feeling_clear">Claro sobre o que importa</string>

    <!-- 7 · O Ori apresenta a jornada -->
    <string name="onboarding_stage_connector_peace">Então vamos passar um bom tempo na Autoaceitação — é onde toda essa jornada começa, e onde a paz encontra seu chão.</string>
    <string name="onboarding_stage_connector_confident">Então o Empoderamento vai importar pra você — aprender a confiar em si e ter o seu próprio lado, um pouco mais a cada dia.</string>
    <string name="onboarding_stage_connector_connected">Então fique de olho na Conexão — fomos feitos pra pertencer, e esses dias caminham você até isso.</string>
    <string name="onboarding_stage_connector_clear">Então é pro Propósito que isso está indo — transformar tudo o que você descobrir numa direção que vale a pena seguir.</string>
    <string name="onboarding_stages_body">Os trinta dias passam por quatro estágios. Começamos com a Autoaceitação, porque tudo o que é mais firme numa vida se constrói sobre se encontrar como você é. Depois o Empoderamento — aprender a ter o seu próprio lado. Depois a Conexão, porque fomos feitos pra pertencer. E por fim o Propósito, onde tudo isso vira uma direção que vale a pena seguir.</string>
    <string name="onboarding_stages_cta">Continuar</string>

    <!-- 8 · Como funciona um dia -->
    <string name="onboarding_day_title">Todo dia é construído da mesma forma, pra que a estrutura possa te sustentar:</string>
    <string name="onboarding_day_reflection">Uma breve reflexão pra dar o tom do dia</string>
    <string name="onboarding_day_prompt">Uma pergunta pra escrever — sua escrita principal</string>
    <string name="onboarding_day_deepdive">Três perguntas pra aprofundar, se quiser ir além</string>
    <string name="onboarding_day_reaffirm">Uma reafirmação pra levar com você</string>
    <string name="onboarding_day_action">Uma ação consciente, em menos de quinze minutos</string>
    <string name="onboarding_day_evening">Uma reflexão à noite pra fechar o dia</string>
    <string name="onboarding_day_cta">Continuar</string>

    <!-- 9 · As promessas -->
    <string name="onboarding_promises_title">Algumas promessas, antes de começar:</string>
    <string name="onboarding_promises_1">Não existe um jeito perfeito de fazer isso.</string>
    <string name="onboarding_promises_2">Perder um dia não é falhar — é ser uma pessoa. Volte quando puder; a página vai esperar.</string>
    <string name="onboarding_promises_3">Escreva o que é verdadeiro, não o que impressiona. Ninguém está corrigindo isso.</string>
    <string name="onboarding_promises_cta">Eu prometo</string>

